# MongoDB Connection String
# Replace with your actual MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_DB=portfolio

# Firebase Configuration
# Replace these with your actual Firebase project credentials
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# ─── GitHub → Telegram notifier (server-side, cron /api/cron/notify) ────
# See docs/gh-notify-setup.md for full setup instructions.

# GitHub Personal Access Token. Fine-grained (recommended) with:
#   Account permissions: Notifications: Read
#   Repository permissions: Contents/Issues/Pull requests: Read-only
# Classic alternative: scopes `notifications` + `repo`.
GH_NOTIFICATIONS_PAT=github_pat_xxx_or_ghp_xxx

# Telegram bot from @BotFather (token like 7234567890:AAH...).
TELEGRAM_BOT_TOKEN=

# Your personal chat ID (integer, positive). Get via:
#   https://api.telegram.org/bot<TOKEN>/getUpdates  after sending the bot a message.
TELEGRAM_CHAT_ID=

# Random hex string. Used to verify Vercel Cron is calling /api/cron/notify.
# Generate with:  openssl rand -hex 32
CRON_SECRET=

# Vercel KV connection vars (KV_URL, KV_REST_API_URL, KV_REST_API_TOKEN,
# KV_REST_API_READ_ONLY_TOKEN) are auto-injected when you provision Vercel KV
# in the dashboard. Do not set manually in production. For local dev, run
# `vercel env pull` to download them.
